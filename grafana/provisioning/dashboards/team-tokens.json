      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#D97757", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#D97757", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-team-daniel" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-team-daniel" },
          "expr": "sum(claude_tokens_total)",
          "legendFormat": "Totalt",
