    {
      "id": 4,
      "title": "⚡ Cache hit %",
      "description": "Andel tokens lästa från Anthropic prompt cache — högt värde = lägre kostnad",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 3 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#37a2cf", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#37a2cf", "value": null }] },
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-team-daniel" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-team-daniel" },
          "expr": "100 * sum(claude_tokens_total{type=\"cache_read\"}) / clamp_min(sum(claude_tokens_total{type=\"input\"}) + sum(claude_tokens_total{type=\"cache_read\"}), 1)",
          "legendFormat": "Cache hit %",
          "refId": "A",
          "instant": true
        }
      ]
    },

